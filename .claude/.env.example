OPENAI_API_KEY=replace-with-openai-compatible-key
OPENAI_BASE_URL=https://api.deepseek.com/v1
TASKCTL_ROUTER_MODEL=deepseek-v4-flash
TASKCTL_ROUTER_TIMEOUT=25
TASKCTL_ROUTER_MAX_TOKENS=900
TASKCTL_ROUTER_RESPONSE_FORMAT=json_object
# Codex gpt-5.4-mini is preferred for schema-constrained routing stability.
# Set provider=openai to use the OpenAI-compatible SDK provider first.
TASKCTL_ROUTER_PROVIDER=codex
TASKCTL_ROUTER_CODEX_MODEL=gpt-5.4-mini
TASKCTL_ROUTER_CODEX_REASONING_EFFORT=low
TASKCTL_ROUTER_CODEX_TIMEOUT=90
TASKCTL_ROUTER_CODEX_FALLBACK=1
TASKCTL_INPUT_GUARD_MODEL=deepseek-v4-flash
TASKCTL_INPUT_GUARD_TIMEOUT=25
TASKCTL_INPUT_GUARD_MAX_TOKENS=500
TASKCTL_INPUT_GUARD_RESPONSE_FORMAT=json_object
TASKCTL_INPUT_GUARD_PROVIDER=codex
TASKCTL_INPUT_GUARD_CODEX_MODEL=gpt-5.4-mini
TASKCTL_INPUT_GUARD_CODEX_REASONING_EFFORT=low
TASKCTL_INPUT_GUARD_CODEX_TIMEOUT=90
TASKCTL_INPUT_GUARD_CODEX_FALLBACK=1
ASSETGEN_CODEX_SANDBOX=workspace
ASSETGEN_CODEX_TIMEOUT=900
